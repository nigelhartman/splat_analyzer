# Copy this file to .env and fill in your values.
# .env is never committed to git.

# SSH access to your GPU server
SERVER_IP=1.2.3.4
SERVER_USER=ubuntu
SSH_KEY=~/.ssh/my_key

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Your domain (must point to SERVER_IP before deploying)
DOMAIN=your-domain.com

# CUDA compute capability of the server GPU
# L40S=8.9  |  A100=8.0  |  RTX 3090/4090=8.6/8.9  |  H100=9.0
CUDA_ARCH_LIST=8.9
